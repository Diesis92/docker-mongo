#######################################
# MONGODB
#######################################

MONGO_IMAGE=mongo:7
MONGO_CONTAINER_NAME=mongodb

MONGO_PORT=27017

MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=super_secure_password

MONGO_INITDB_DATABASE=appdb

MONGO_RESTART_POLICY=unless-stopped

#######################################
# MONGO EXPRESS
#######################################

MONGO_EXPRESS_IMAGE=mongo-express:latest
MONGO_EXPRESS_CONTAINER_NAME=mongo-express

MONGO_EXPRESS_PORT=8081

MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=admin123

MONGO_EXPRESS_RESTART_POLICY=unless-stopped

#######################################
# TIMEZONE
#######################################

TZ=Europe/Rome